{% if not id %}
  {% set id = 'table' ~ random() %}
{% endif %}
{% set rand = random() %}
{% set config_id = id ~ '_config' %}
{% set has_remote_data = url is defined and url %}
{% set has_massive_action = massive_action is defined %}
{% set has_radio_selection = radio is defined and radio %}
{% set table_itemtype = itemtype is defined ? itemtype : '' %}
{% set table_state_key = state_key is defined ? state_key : (table_itemtype ? table_itemtype : id) %}
{% set toolbar_enabled = not (minimal is defined and minimal) and not (noToolBar is defined and noToolBar) %}

<div
  class="bootstrap-table bootstrap5"
  id="{{ id|e('html_attr') }}"
  data-itsm-table-config="{{ config_id|e('html_attr') }}"
></div>

{% if has_radio_selection %}
<input id="table_input{{ id|e('html_attr') }}" type="hidden" name="{{ radio|e('html_attr') }}" value=''>
{% endif %}

<script type="application/json" id="{{ config_id|e('html_attr') }}">
{
    "id": {{ id|json_encode|raw }},
    "stateKey": {{ table_state_key|json_encode|raw }},
    "itemtype": {{ table_itemtype|json_encode|raw }},
    "columns": [
        {% for key, value in fields %}
            {
                "id": {{ key|json_encode|raw }},
                "label": {{ value|json_encode|raw }},
                "html": true
            }{% if not loop.last %},{% endif %}
        {% endfor %}
    ],
    "dataSource": {
        "type": {{ (has_remote_data ? 'remote' : 'local')|json_encode|raw }},
        "url": {{ has_remote_data ? url|json_encode|raw : "null" }},
        "rows": {{ has_remote_data ? '[]' : values|json_encode|raw }}
    },
    "selection": {
        "type": {{ (has_radio_selection ? 'radio' : (has_massive_action ? 'massive-action' : 'none'))|json_encode|raw }},
        "values": {{ has_massive_action ? massive_action|json_encode|raw : "[]" }},
        "inputId": {{ has_radio_selection ? ('table_input' ~ id)|json_encode|raw : "null" }}
    },
    "toolbar": {
        "enabled": {{ toolbar_enabled ? 'true' : 'false' }},
        "columns": true,
        "massiveAction": {{ has_massive_action ? 'true' : 'false' }},
        "displayPreferences": {{ column_edit is defined and column_edit ? "true" : "false" }},
        "trash": {
            "enabled": {{ can_trash is defined and can_trash ? "true" : "false" }},
            "isTrash": {{ is_trash is defined and is_trash ? "true" : "false" }}
        },
        "id": {{ ('toolbar' ~ rand)|json_encode|raw }}
    },
    "view": {
        "pageSize": {{ pageSize is defined ? pageSize : 15 }}
    },
    "export": {
        "enabled": {{ show_export is defined ? (show_export ? "true" : "false") : "true" }},
        "target": {{ export_target is defined ? export_target|json_encode|raw : "null" }},
        "params": {{ export_params is defined ? export_params|json_encode|raw : "null" }}
    },
    "search": {
        "enabled": {{ search is defined and search ? "true" : "false" }},
        "placeholder": {{ search_placeholder is defined ? search_placeholder|json_encode|raw : "Search"|json_encode|raw }}
    }
}
</script>
